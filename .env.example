DATABASE_URL="postgresql://scheduler:scheduler@localhost:5432/scheduler?schema=public"

# Auth — Microsoft Entra ID (multi-tenant + personal accounts)
AZURE_AD_CLIENT_ID=
AZURE_AD_CLIENT_SECRET=
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Resend — for transactional emails (invitations, password resets)
RESEND_API_KEY=
# EMAIL_FROM — must use a verified domain in Resend for delivery beyond the account owner's own inbox
# e.g. "Scheduling Platform <onboarding@yourdomain.com>"
EMAIL_FROM=

# Next.js (optional overrides)
# NEXT_PUBLIC_BASE_URL=http://localhost:3002
