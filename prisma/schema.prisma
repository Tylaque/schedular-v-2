generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProjectStatus {
  draft
  active
  paused
  closed
  archived
}

enum ParticipantStatus {
  invited
  link_sent
  booked
  reminded
  completed
  no_show
  cancelled
  waitlisted
}

enum WaitlistStatus {
  waiting
  offered
  expired
  claimed
  cancelled
}

enum BookingStatus {
  confirmed
  cancelled
  rescheduled
}

enum TeamsProvisionStatus {
  pending
  provisioned
  failed_personal_account
  failed_insufficient_permissions
  failed_unknown
}

enum EmailCategory {
  admin_invitation
  availability_request
  participant_invitation
  booking_confirmation
  reminder_24h
  reminder_1h
  reschedule_notice
  cancellation_notice
  waitlist_offer
}

enum EmailAudience {
  admin
  participant
  super_admin
}

enum AdminRole {
  admin
  super_admin
  org_owner
}

enum AdminAccountType {
  organizational
  personal
  no_microsoft
  unknown
}

enum NotificationStatus {
  sent
  failed
  test
}

model Admin {
  id                 String              @id @default(cuid())
  name               String
  initials           String              @default("")
  email              String              @unique
  emailVerified      DateTime?
  passwordHash       String?
  role               AdminRole           @default(admin)
  accountType        AdminAccountType    @default(unknown)
  projectAssignments ProjectAdmin[]
  availabilityEntries AdminAvailability[]
  bookings           Booking[]
  ownedProjects      Project[]           @relation("ProjectOwner")
  passwordResetTokens PasswordResetToken[]
  accounts           Account[]
  sessions           Session[]
  createdAt          DateTime            @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user Admin @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user Admin @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Project {
  id                        String         @id @default(cuid())
  slug                      String         @unique
  name                      String
  company                   String
  description               String
  durationMinutes           Int
  availabilityPeriodDays    Int
  dailyStart                String
  dailyEnd                  String
  includeWeekends           Boolean        @default(false)
  minNoticeHours            Int
  timezone                  String
  bookingDeadlineDays       Int
  bufferMinutes             Int
  maxSessionsPerAdminPerDay Int
  sessionCapacity           Int            @default(1)
  selfServiceWindowHours    Int            @default(4)
  status                    ProjectStatus  @default(draft)
  availabilityLockDate      DateTime
  brandingLogoInitial       String
  brandingPrimaryColor      String
  brandingSenderName        String
  admins                    ProjectAdmin[]
  availabilityEntries       AdminAvailability[]
  participants              Participant[]
  bookings                  Booking[]
  waitlistEntries           WaitlistEntry[]
  emailTemplates            EmailTemplate[]
  notificationLogs          NotificationLog[]
  auditLogs                 AuditLog[]
  ownerId                   String?
  owner                     Admin?         @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  createdAt                 DateTime       @default(now())
  updatedAt                 DateTime       @updatedAt
}

model ProjectAdmin {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  adminId   String
  createdAt DateTime @default(now())

  @@unique([projectId, adminId])
}

model AdminAvailability {
  id        String   @id @default(cuid())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  adminId   String
  dateKey   String
  time      String
  createdAt DateTime @default(now())

  @@unique([projectId, adminId, dateKey, time])
  @@index([projectId, dateKey])
}

model Participant {
  id           String            @id @default(cuid())
  project      Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId    String
  name         String
  email        String
  customFields Json?
  status       ParticipantStatus @default(invited)
  createdAt    DateTime          @default(now())

  @@unique([projectId, email])
}

model Booking {
  id               String        @id @default(cuid())
  project          Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId        String
  admin            Admin         @relation(fields: [adminId], references: [id], onDelete: Cascade)
  adminId          String
  participantName  String
  participantEmail String
  dateKey          String
  time             String
  status           BookingStatus @default(confirmed)
  teamsMeetingId      String?
  calendarEventId     String?
  teamsProvisionStatus TeamsProvisionStatus?
  teamsJoinUrl        String?
  teamsErrorDetail    String?
  rescheduledFrom     Booking?      @relation("BookingReschedule", fields: [rescheduledFromId], references: [id])
  rescheduledFromId String?      @unique
  rescheduledTo    Booking?      @relation("BookingReschedule")
  createdAt        DateTime      @default(now())

  // No @@unique here — see migration for partial unique index on confirmed bookings only
  // @@unique([projectId, dateKey, time]) would be WRONG: it caps every slot at 1 regardless of sessionCapacity.
  // The partial unique index guards capacity=1 at the DB level; application logic in createBooking()
  // enforces capacity >1 by counting before insert inside a serializable transaction.
}

model WaitlistEntry {
  id               String         @id @default(cuid())
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId        String
  name             String
  email            String
  dateKey          String?
  time             String?
  status           WaitlistStatus @default(waiting)
  offeredAt        DateTime?
  expiresAt        DateTime?
  claimedBookingId String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([projectId, status, createdAt])
  @@index([projectId, dateKey, time, status])
}

model EmailTemplate {
  id               String            @id @default(cuid())
  category         EmailCategory
  audience         EmailAudience
  project          Project?          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId        String?
  subject          String
  bodyHtml         String
  version          Int               @default(1)
  isActive         Boolean           @default(true)
  notificationLogs NotificationLog[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([category, projectId, isActive])
}

model NotificationLog {
  id             String              @id @default(cuid())
  template       EmailTemplate?      @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateId     String?
  category       EmailCategory
  project        Project?            @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId      String?
  recipientEmail String
  recipientRole  EmailAudience
  subject        String
  renderedBody   String
  status         NotificationStatus
  createdAt      DateTime            @default(now())
}

enum AuditAction {
  project_created
  project_updated
  admin_availability_submitted
  booking_created
  booking_cancelled
  booking_rescheduled
  template_created
  template_updated
  notification_sent
  waitlist_joined
}

model AuditLog {
  id          String      @id @default(cuid())
  action      AuditAction
  actorType   String
  actorId     String?
  actorLabel  String
  entityType  String
  entityId    String
  project     Project?    @relation(fields: [projectId], references: [id], onDelete: SetNull)
  projectId   String?
  beforeState Json?
  afterState  Json?
  createdAt   DateTime    @default(now())

  @@index([entityType, entityId])
  @@index([projectId, createdAt])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  adminId   String
  token     String   @unique
  expires   DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([adminId])
}
